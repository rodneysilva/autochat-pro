# ===========================================
# AutoChat Pro - Variáveis de Ambiente
# ===========================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SEUS VALORES
# ===========================================

# Ambiente
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# Servidor
HOST=0.0.0.0
PORT=8000

# ===========================================
# ⚠️ SEGURANÇA - OBRIGATÓRIO ALTERAR EM PRODUÇÃO ⚠️
# ===========================================

# Chave secreta para JWT - GERE UMA CHAVE FORTE ALEATÓRIA
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_AQUI_MUITO_LONGA_E_COMPLEXA

# Algoritmo de assinatura JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# BANCO DE DADOS
# ===========================================

# MongoDB - Use senhas fortes em produção
MONGODB_URL=mongodb://admin:SUASENHAMONGODB@mongodb:27017/?authSource=admin
DATABASE_NAME=autochat_pro

# Redis - Use senha em produção
REDIS_URL=redis://:SUASENHAREDIS@redis:6379/0

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===========================================
# EMAIL (SMTP)
# ===========================================
# Configure seu servidor SMTP ou use serviços como SendGrid, Mailgun, etc.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=AutoChat Pro <noreply@seudominio.com>
MAIL_PORT=587
MAIL_SERVER=smtp.seuprovedor.com
MAIL_FROM_NAME=AutoChat Pro
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ===========================================
# SMS (Opcional - Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# LLM (Opcional)
# ===========================================
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=glm-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ===========================================
# WHATSAPP (Evolution API)
# ===========================================
WHATSAPP_API_URL=http://evolution-api:8080
# GERE UMA API KEY FORTE PARA EVOLUTION API
WHATSAPP_API_KEY=GERE_UMA_API_KEY_AQUI

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_FREE=100
RATE_LIMIT_BASIC=300
RATE_LIMIT_PRO=1000

# ===========================================
# PLANOS
# ===========================================
TRIAL_DAYS=14

# ===========================================
# FRONTEND
# ===========================================
FRONTEND_URL=http://localhost:5173

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
