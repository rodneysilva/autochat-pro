# ===========================================
# AutoChat Pro - Variáveis de Ambiente
# ===========================================

# Ambiente
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Servidor
HOST=0.0.0.0
PORT=8000

# Segurança
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB
MONGODB_URL=mongodb://mongodb:27017
DATABASE_NAME=autochat_pro

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email (FastAPI-Mail)
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_FROM=AutoChat Pro <noreply@autochat.pro>
MAIL_PORT=587
MAIL_SERVER=smtp.sendgrid.net
MAIL_FROM_NAME=AutoChat Pro
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# LLM - GLM
LLM_API_URL=http://localhost:8000/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=glm-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# WhatsApp (Evolution API ou similar)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=your-whatsapp-api-key

# Telegram (configurado por bot)
# Não é necessário variável global

# Rate Limiting
RATE_LIMIT_FREE=100
RATE_LIMIT_BASIC=300
RATE_LIMIT_PRO=1000

# Planos ( dias de trial)
TRIAL_DAYS=14

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
