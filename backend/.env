# ===========================================
# AutoChat Pro - Variáveis de Ambiente
# ===========================================

# Ambiente
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Servidor
HOST=0.0.0.0
PORT=8000

# Segurança
SECRET_KEY=autochat-secret-key-development-mudar-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB
MONGODB_URL=mongodb://admin:admin123@mongodb:27017/?authSource=admin
DATABASE_NAME=autochat_pro

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email (FastAPI-Mail) - Postfix Local
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=AutoChat Pro <noreply@rodney.website>
MAIL_PORT=25
MAIL_SERVER=postfix
MAIL_FROM_NAME=AutoChat Pro
MAIL_STARTTLS=false
MAIL_SSL_TLS=false

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# LLM - GLM
LLM_API_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL=glm-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# WhatsApp (Evolution API)
WHATSAPP_API_URL=http://evolution-api:8080
WHATSAPP_API_KEY=evolution_api_key_secret_change_in_production


# Rate Limiting
RATE_LIMIT_FREE=100
RATE_LIMIT_BASIC=300
RATE_LIMIT_PRO=1000

# Planos
TRIAL_DAYS=14

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
